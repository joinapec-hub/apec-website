# Copy to .env.local for local development. Do NOT commit real values.

# Resend — contact form email delivery
RESEND_API_KEY=

# TixFox — read-only API key used to sync the events list on /events.
# Get it from the TixFox dashboard (Integration → API Key).
# In production, set this in Vercel → Settings → Environment Variables.
TIXFOX_API_KEY=

# TixFox — webhook signing secret (only needed if/when the order webhook
# receiver at /api/tixfox/webhook is enabled).
TIXFOX_WEBHOOK_SECRET=

# Stripe — webhook signing secret (whsec_...) for the membership/donation
# webhook at /api/stripe/webhook. Create the endpoint in the Stripe Dashboard
# (Developers → Webhooks), subscribe to "checkout.session.completed", and copy
# the signing secret here. No Stripe API key is needed.
STRIPE_WEBHOOK_SECRET=

# Optional member "database" sink — a POST endpoint that appends each signup to
# a store you control (e.g. a Google Sheet via an Apps Script Web App URL).
# Leave blank to rely on Stripe + email notifications only.
MEMBER_SINK_URL=
