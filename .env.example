# Copy to .env.local for local development. Do NOT commit real values.

# Resend — contact form email delivery
RESEND_API_KEY=

# TixFox — read-only API key used to sync the events list on /events.
# Get it from the TixFox dashboard (Integration → API Key).
# In production, set this in Vercel → Settings → Environment Variables.
TIXFOX_API_KEY=

# TixFox — webhook signing secret (only needed if/when the order webhook
# receiver at /api/tixfox/webhook is enabled).
TIXFOX_WEBHOOK_SECRET=
